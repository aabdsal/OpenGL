{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar OpenGL",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=c++17",
                "-stdlib=libc++",
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I${workspaceFolder}/codebase",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-lfreeimage",
                "-lserialport",
                "-framework",
                "GLUT",
                "-framework",
                "OpenGL",
                "-Wno-deprecated",
                //"&&",
                //"${fileDirname}/${fileBasenameNoExtension}",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Compilador clang++ con frameworks OpenGL, GLUT, FreeImage, SerialPort y uso de terminal"
        }
    ]
}